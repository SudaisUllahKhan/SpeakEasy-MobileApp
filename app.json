{
  "expo": {
    "name": "SpeakEasy",
    "slug": "speakeasy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "speakeasy",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.innov8ive.speakeasy",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SpeakEasy needs microphone access to record your spoken answers for pronunciation scoring.",
        "NSCameraUsageDescription": "SpeakEasy may need camera access for profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "ai.innov8ive.speakeasy",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "speakeasy"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "SpeakEasy needs microphone access to record your spoken answers for pronunciation scoring."
        }
      ]
    ],
    "newArchEnabled": false,
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/398c7481-800e-4754-b48a-727981d15cb9"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "398c7481-800e-4754-b48a-727981d15cb9"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
